{
  "name": "fuelnfreetime",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "npm run build:admin",
    "build:admin": "npm run build --prefix admin-ui",
    "dev:admin": "npm run dev --prefix admin-ui",
    "dev": "wrangler dev",
    "deploy": "npm run build:admin && ./scripts/with-cf-admin-env.sh npx wrangler deploy",
    "deploy:plain": "wrangler deploy",
    "db:migrate": "wrangler d1 execute fuelnfreetime --remote --file=db/schema.sql",
    "db:migrate:local": "wrangler d1 execute fuelnfreetime --local --file=db/schema.sql",
    "db:seed:cms": "wrangler d1 execute fuelnfreetime --remote --file=db/seed-cms.sql",
    "db:seed:cms:full": "wrangler d1 execute fuelnfreetime --remote --file=db/seed-cms-full.sql",
    "db:seed:cms:local": "wrangler d1 execute fuelnfreetime --local --file=db/seed-cms.sql",
    "db:seed:cms:full:local": "wrangler d1 execute fuelnfreetime --local --file=db/seed-cms-full.sql",
    "db:seed:tee": "wrangler d1 execute fuelnfreetime --remote --file=db/seed-tee.sql",
    "db:seed:platform": "./scripts/with-cf-admin-env.sh npx wrangler d1 execute fuelnfreetime --remote --file=db/seed-platform.sql",
    "cms:generate-seed": "node scripts/generate-cms-seed.mjs",
    "cms:bootstrap": "npm run cms:generate-seed && npm run db:seed:cms:full && npm run db:seed:tee",
    "cms:warm": "node scripts/warm-cms-cache.mjs",
    "cms:republish": "node scripts/republish-cms-kv.mjs && npm run cms:warm",
    "db:migrate:media": "./scripts/with-cf-admin-env.sh npx wrangler d1 execute fuelnfreetime --remote --file=db/migrate-media-library.sql",
    "db:migrate:agentsam-platform": "./scripts/with-cf-admin-env.sh npx wrangler d1 execute fuelnfreetime --remote --file=db/migrate-agentsam-platform.sql",
    "db:migrate:agentsam-workflows": "./scripts/with-cf-admin-env.sh npx wrangler d1 execute fuelnfreetime --remote --file=db/migrate-agentsam-workflows.sql",
    "db:migrate:agentsam-workflows-v2": "bash scripts/apply-agentsam-workflows-v2.sh",
    "db:seed:agentsam-platform": "./scripts/with-cf-admin-env.sh npx wrangler d1 execute fuelnfreetime --remote --file=db/seed-agentsam-platform.sql",
    "db:seed:agentsam-workflows": "./scripts/with-cf-admin-env.sh npx wrangler d1 execute fuelnfreetime --remote --file=db/seed-agentsam-workflows.sql",
    "db:seed:agentsam-workflows-studio": "./scripts/with-cf-admin-env.sh npx wrangler d1 execute fuelnfreetime --remote --file=db/seed-agentsam-workflows-studio.sql",
    "db:seed:agentsam-workflow-nodes-studio": "./scripts/with-cf-admin-env.sh npx wrangler d1 execute fuelnfreetime --remote --file=db/seed-agentsam-workflow-nodes-studio.sql",
    "db:install:agentsam-workflows": "npm run db:migrate:agentsam-workflows && npm run db:seed:agentsam-workflows",
    "db:install:agentsam-studio": "npm run db:migrate:agentsam-workflows-v2 && npm run db:seed:agentsam-workflows-studio && npm run db:seed:agentsam-workflow-nodes-studio",
    "db:migrate:agentsam-skills": "./scripts/with-cf-admin-env.sh npx wrangler d1 execute fuelnfreetime --remote --file=db/migrate-agentsam-platform.sql",
    "db:migrate:cms-r2": "./scripts/with-cf-admin-env.sh npx wrangler d1 execute fuelnfreetime --remote --file=db/migrate-cms-r2.sql",
    "agentsam:skills:sync": "node scripts/sync-agentsam-skills.mjs",
    "db:migrate:project-context": "./scripts/with-cf-admin-env.sh npx wrangler d1 execute fuelnfreetime --remote --file=db/migrate-agentsam-project-context.sql",
    "db:seed:ctx-fuelnfreetime": "./scripts/with-cf-admin-env.sh npx wrangler d1 execute fuelnfreetime --remote --file=db/migrate-agentsam-project-context.sql && ./scripts/with-cf-admin-env.sh npx wrangler d1 execute fuelnfreetime --remote --file=db/seed-ctx-fuelnfreetime-worker.sql",
    "db:seed:ctx-fuelnfreetime:iam": "./scripts/with-cf-admin-env.sh npx wrangler d1 execute inneranimalmedia-business --remote -c ../inneranimalmedia/wrangler.production.toml --file=db/seed-ctx-fuelnfreetime-iam.sql",
    "db:seed:ctx-fuelnfreetime:all": "npm run db:seed:ctx-fuelnfreetime && npm run db:seed:ctx-fuelnfreetime:iam",
    "db:migrate:auth-users": "./scripts/with-cf-admin-env.sh npx wrangler d1 execute fuelnfreetime --remote --file=db/migrate-auth-users.sql",
    "db:migrate:auth-users-slim": "./scripts/with-cf-admin-env.sh npx wrangler d1 execute fuelnfreetime --remote --file=db/migrate-auth-users-slim.sql",
    "db:migrate:auth-users-finalize": "./scripts/with-cf-admin-env.sh npx wrangler d1 execute fuelnfreetime --remote --file=db/migrate-auth-users-finalize.sql",
    "db:seed:auth-display-names": "./scripts/with-cf-admin-env.sh npx wrangler d1 execute fuelnfreetime --remote --file=db/seed-auth-display-names.sql",
    "admin:create": "node scripts/create-admin.mjs",
    "r2:cors": "./scripts/with-cf-admin-env.sh npx wrangler r2 bucket cors set fuelnfreetime --file=scripts/r2-cors.json -y",
    "analytics:unpack": "node scripts/unpack-analytics.mjs",
    "dns:check": "node scripts/check-dns.mjs",
    "cf:status": "./scripts/with-cf-admin-env.sh node scripts/cf-status.mjs"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
