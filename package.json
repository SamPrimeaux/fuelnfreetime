{
  "name": "fuelnfreetime",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "npm run build:admin",
    "build:admin": "npm run build --prefix admin-ui",
    "dev:admin": "npm run dev --prefix admin-ui",
    "dev": "wrangler dev",
    "deploy": "npm run build:admin && ./scripts/with-cf-admin-env.sh npx wrangler deploy",
    "deploy:plain": "wrangler deploy",
    "db:migrate": "wrangler d1 execute fuelnfreetime --remote --file=db/schema.sql",
    "db:migrate:local": "wrangler d1 execute fuelnfreetime --local --file=db/schema.sql",
    "db:seed:cms": "wrangler d1 execute fuelnfreetime --remote --file=db/seed-cms.sql",
    "db:seed:cms:full": "wrangler d1 execute fuelnfreetime --remote --file=db/seed-cms-full.sql",
    "db:seed:cms:local": "wrangler d1 execute fuelnfreetime --local --file=db/seed-cms.sql",
    "db:seed:cms:full:local": "wrangler d1 execute fuelnfreetime --local --file=db/seed-cms-full.sql",
    "db:seed:tee": "wrangler d1 execute fuelnfreetime --remote --file=db/seed-tee.sql",
    "cms:generate-seed": "node scripts/generate-cms-seed.mjs",
    "cms:bootstrap": "npm run cms:generate-seed && npm run db:seed:cms:full && npm run db:seed:tee",
    "cms:warm": "node scripts/warm-cms-cache.mjs",
    "cms:republish": "node scripts/republish-cms-kv.mjs && npm run cms:warm",
    "db:migrate:media": "./scripts/with-cf-admin-env.sh npx wrangler d1 execute fuelnfreetime --remote --file=db/migrate-media-library.sql",
    "db:migrate:cms-r2": "./scripts/with-cf-admin-env.sh npx wrangler d1 execute fuelnfreetime --remote --file=db/migrate-cms-r2.sql",
    "admin:create": "node scripts/create-admin.mjs",
    "r2:cors": "./scripts/with-cf-admin-env.sh npx wrangler r2 bucket cors set fuelnfreetime --file=scripts/r2-cors.json -y",
    "analytics:unpack": "node scripts/unpack-analytics.mjs",
    "dns:check": "node scripts/check-dns.mjs",
    "cf:status": "./scripts/with-cf-admin-env.sh node scripts/cf-status.mjs"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
