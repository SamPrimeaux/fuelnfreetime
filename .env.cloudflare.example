# Fuel & Free Time — local Cloudflare + Resend (copy to .env.cloudflare)
# NEVER commit .env.cloudflare

CLOUDFLARE_ACCOUNT_ID=ede6590ac0d2fb7daf155b35653457b2

# Token with Zone:Read + Zone:DNS:Edit for fuelnfreetime.com (optional, for dns:setup:resend)
CLOUDFLARE_API_TOKEN=

# Resend — fuelnfreetime.com customer project
RESEND_API_KEY=re_
RESEND_WEBHOOK_SECRET_OUTBOUND=whsec_
RESEND_WEBHOOK_SECRET_INBOUND=whsec_

# CMS — Workers Builds deploy hook (fuelnfreetime-cms-deployhook / main)
CMS_DEPLOY_HOOK_URL=https://api.cloudflare.com/client/v4/workers/builds/deploy_hooks/YOUR_HOOK_ID

# CMS — post-deploy KV warm (wrangler secret put CMS_WARM_SECRET)
CMS_WARM_SECRET=

# Worker base URL for scripts (optional)
FNF_WORKER_URL=https://fuelnfreetime.com
